<Window
    x:Class="ReviewBauturi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ReviewBauturi"
    xmlns:models="using:ReviewBauturi.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer>
        <StackPanel Padding="30" Spacing="15">
            <TextBlock Text="Adaugă un Review Nou" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBox x:ConnectionId='2' x:Name="InputNumeBautura" PlaceholderText="Nume Băutură (ex: Espresso)"/>
            <TextBox x:ConnectionId='3' x:Name="InputCategorie" PlaceholderText="Categorie (ex: Cafea)"/>

            <StackPanel Orientation="Horizontal" Spacing="20">
                <StackPanel>
                    <TextBlock Text="Preț:" Margin="0,0,0,5"/>
                    <controls:NumberBox x:ConnectionId='15' x:Name="InputPret" Value="0" SmallChange="0.5" Width="150"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Rating (1-5):" Margin="0,0,0,5"/>
                    <Slider x:ConnectionId='14' x:Name="InputRating" Minimum="1" Maximum="5" StepFrequency="1" Width="200" TickPlacement="Outside"/>
                </StackPanel>
            </StackPanel>

            <TextBox x:ConnectionId='4' x:Name="InputComentariu" PlaceholderText="Scrie părerea ta aici..." 
                     AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>

            <Button x:ConnectionId='5' Content="Salvează Review"                            
                    Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>

            <MenuFlyoutSeparator Margin="0,20"/>

            <TextBlock Text="Toate Review-urile" FontSize="20" FontWeight="SemiBold"/>
            <ListView x:ConnectionId='6' x:Name="ListaBauturi">
                <ListView.ItemTemplate>
                    <DataTemplate                             >
                        <StackPanel x:ConnectionId='8' Margin="0,15" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:ConnectionId='12'                      FontWeight="Bold" FontSize="18"/>

                                <TextBlock x:ConnectionId='13' Grid.Column="1"                              Foreground="Green" FontWeight="SemiBold"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock x:ConnectionId='10'                          FontStyle="Italic" Foreground="Gray"/>
                                <TextBlock Text="|" Foreground="LightGray"/>

                                <TextBlock x:ConnectionId='11'                               FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock x:ConnectionId='9'                         TextWrapping="Wrap" Margin="0,5,0,0" Foreground="DimGray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Window>

