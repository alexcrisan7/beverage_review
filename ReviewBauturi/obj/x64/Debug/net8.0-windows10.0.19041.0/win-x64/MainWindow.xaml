<Window
    x:Class="ReviewBauturi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ReviewBauturi"
    xmlns:models="using:ReviewBauturi.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <Grid x:ConnectionId='2' x:Name="AuthGrid" VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
            <StackPanel x:ConnectionId='28' x:Name="WelcomePanel" Spacing="15">
                <TextBlock Text="DrinkReview" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                <TextBlock Text="Aplicația ta de notare a băuturilor" Foreground="Gray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button x:ConnectionId='41' Content="Autentificare"                         HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Height="45" FontSize="16"/>
                <Button x:ConnectionId='42' Content="Creare cont nou"                            HorizontalAlignment="Stretch" Height="45" FontSize="16"/>
            </StackPanel>

            <StackPanel x:ConnectionId='29' x:Name="LoginPanel" Spacing="15" Visibility="Collapsed">
                <TextBlock Text="Autentificare" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:ConnectionId='36' x:Name="LoginUsername" PlaceholderText="Nume utilizator"/>
                <PasswordBox x:ConnectionId='37' x:Name="LoginPassword" PlaceholderText="Parolă"/>
                <Button x:ConnectionId='38' Content="Intră în cont"                     HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Height="40"/>
                <Button x:ConnectionId='39' Content="Înapoi"                             HorizontalAlignment="Stretch" Background="Transparent" BorderBrush="Transparent"/>
                <TextBlock x:ConnectionId='40' x:Name="EroareLogin" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel x:ConnectionId='30' x:Name="RegisterPanel" Spacing="15" Visibility="Collapsed">
                <TextBlock Text="Cont Nou" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:ConnectionId='31' x:Name="RegisterUsername" PlaceholderText="Alege un nume de utilizator"/>
                <PasswordBox x:ConnectionId='32' x:Name="RegisterPassword" PlaceholderText="Alege o parolă"/>
                <Button x:ConnectionId='33' Content="Creează contul"                        HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Height="40"/>
                <Button x:ConnectionId='34' Content="Înapoi"                             HorizontalAlignment="Stretch" Background="Transparent" BorderBrush="Transparent"/>
                <TextBlock x:ConnectionId='35' x:Name="EroareRegister" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <ScrollViewer x:ConnectionId='3' x:Name="MainAppPanel" Visibility="Collapsed">
            <StackPanel Padding="30" Spacing="15">

                <Grid>
                    <TextBlock Text="Adaugă un Review Nou" FontSize="24" FontWeight="Bold"/>
                    <Button x:ConnectionId='27' Content="Delogare"                      HorizontalAlignment="Right"/>
                </Grid>

                <TextBox x:ConnectionId='4' x:Name="InputNumeBautura" PlaceholderText="Nume Băutură (ex: Espresso)"/>

                <ComboBox x:ConnectionId='5' x:Name="InputCategorie" PlaceholderText="Selectează Categoria" HorizontalAlignment="Stretch">
                    <x:String>Cafea</x:String>
                    <x:String>Bere</x:String>
                    <x:String>Vin</x:String>
                    <x:String>Cocktail</x:String>
                    <x:String>Ceai / Răcoritoare</x:String>
                    <x:String>Spirtoase</x:String>
                </ComboBox>

                <AutoSuggestBox x:ConnectionId='6' x:Name="InputRestaurant" PlaceholderText="Unde ai băut? (Căutare locație...)" 
                                                                          QueryIcon="Find"/>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <StackPanel>
                        <TextBlock Text="Preț:" Margin="0,0,0,5"/>
                        <controls:NumberBox x:ConnectionId='26' x:Name="InputPret" Value="0" SmallChange="0.5" Width="150"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Rating (1-5):" Margin="0,0,0,5"/>
                        <Slider x:ConnectionId='25' x:Name="InputRating" Minimum="1" Maximum="5" StepFrequency="1" Width="200" TickPlacement="Outside"/>
                    </StackPanel>
                </StackPanel>

                <TextBox x:ConnectionId='7' x:Name="InputComentariu" PlaceholderText="Scrie părerea ta aici..." AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>
                <Button x:ConnectionId='8' Content="Salvează Review"                            Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>

                <MenuFlyoutSeparator Margin="0,20"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Filtrează Review-urile" FontWeight="SemiBold" FontSize="18"/>

                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <ComboBox x:ConnectionId='20' x:Name="FilterCategory" PlaceholderText="Categorie" Width="150" SelectedIndex="0">
                                <x:String>Toate</x:String>
                                <x:String>Cafea</x:String>
                                <x:String>Bere</x:String>
                                <x:String>Vin</x:String>
                                <x:String>Cocktail</x:String>
                                <x:String>Ceai / Răcoritoare</x:String>
                                <x:String>Spirtoase</x:String>
                            </ComboBox>

                            <TextBox x:ConnectionId='21' x:Name="FilterLocation" PlaceholderText="Cuvânt locație..." Width="150"/>

                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="Preț Max:" VerticalAlignment="Center"/>
                                <controls:NumberBox x:ConnectionId='24' x:Name="FilterPrice" Value="0" Width="100"/>
                            </StackPanel>

                            <Button x:ConnectionId='22' Content="Caută"                            Style="{StaticResource AccentButtonStyle}"/>
                            <Button x:ConnectionId='23' Content="Reset"                           />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListView x:ConnectionId='9' x:Name="ListaBauturi" Margin="0,10,0,0">
                    <ListView.ItemTemplate>
                        <DataTemplate                             >
                            <StackPanel x:ConnectionId='11' Margin="0,15" Background="Transparent" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='18'                      FontWeight="Bold" FontSize="18"/>
                                    <TextBlock x:ConnectionId='19' Grid.Column="1"                              Foreground="Green" FontWeight="SemiBold"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                    <TextBlock x:ConnectionId='16'                          FontStyle="Italic" Foreground="Gray"/>
                                    <TextBlock Text="|" Foreground="LightGray"/>
                                    <TextBlock x:ConnectionId='17'                               FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock x:ConnectionId='12'                                 Foreground="DarkCyan" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock x:ConnectionId='13'                         TextWrapping="Wrap" Margin="0,5,0,0" Foreground="DimGray"/>

                                <Grid Margin="0,10,0,0">
                                    <TextBlock x:ConnectionId='14'                                FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                                    <Button x:ConnectionId='15' Content="Șterge" HorizontalAlignment="Right" Foreground="Red"                                                                                          />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

